# =============================================================================
# Sefaria Book Creator — Production Environment
# =============================================================================
# Copy this file to .env.production and fill in your values.
# NEVER commit .env.production to version control!

# -- App settings --
ENVIRONMENT=production
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_64_CHARS
ALLOWED_HOSTS=your-domain.com,your-public-ip

# -- Database --
POSTGRES_DB=sefaria_books
POSTGRES_USER=sefaria
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://sefaria:CHANGE_ME_STRONG_PASSWORD@db:5432/sefaria_books

# -- Redis --
REDIS_URL=redis://redis:6379/0

# -- Celery --
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# -- Frontend --
# Set this to your public URL (what users type in the browser).
# Nginx will proxy /api/* to the backend automatically.
NEXT_PUBLIC_API_URL=http://your-public-ip

# -- Worker --
CELERY_CONCURRENCY=1

# -- Domain (for SSL/Certbot) --
# DOMAIN=your-domain.com
# EMAIL=your-email@example.com
