# =============================================================
# Sefaria Book Creator — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://sefaria:sefaria@postgres:5432/sefaria
POSTGRES_USER=sefaria
POSTGRES_PASSWORD=sefaria
POSTGRES_DB=sefaria

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Application ───────────────────────────────────────────────
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-a-secure-random-key>
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── PDF Generation ────────────────────────────────────────────
# Directory inside the container where generated PDFs are written
PDF_OUTPUT_DIR=/tmp/pdf_output

# ── Frontend ──────────────────────────────────────────────────
# URL the browser uses to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
